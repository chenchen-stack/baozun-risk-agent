# 复制为 env.deploy（不要提交 Git），填写后可在 PowerShell 中:
#   Get-Content env.deploy | ForEach-Object { if ($_ -match '^([^#=]+)=(.*)$') { Set-Item -Path "env:$($matches[1])" -Value $matches[2].Trim() } }; .\scripts\deploy-aliyun.ps1

ALIYUN_ACR_REGISTRY=registry.cn-hangzhou.aliyuncs.com
ALIYUN_ACR_NAMESPACE=你的命名空间
ALIYUN_ACR_REPO=baozun-risk-agent
ALIYUN_ACR_TAG=v1
ALIYUN_ACR_USERNAME=你的阿里云登录名或RAM子账号
ALIYUN_ACR_PASSWORD=ACR控制台设置的固定密码或临时令牌
