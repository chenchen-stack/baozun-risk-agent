# 复制本文件为 .env（与 server.py 同目录），填入密钥后保存。
# 获取密钥: https://platform.deepseek.com/
DEEPSEEK_API_KEY=
# 与上一行二选一或并存：优先使用请求头，其次 LLM_API_KEY，再次 DEEPSEEK_API_KEY
# LLM_API_KEY=

# 可选：OpenAI 兼容接口（火山引擎 / 通义千问 等）— 与 DEEPSEEK 二选一部署场景
# LLM_OPENAI_API_BASE=https://你的兼容网关/v1
# LLM_MODEL=qwen-plus

# 可选：单条用户消息内 Agent 工具循环上限（默认 36；复杂任务可设 32～40，最大 80）
# AGENT_MAX_ITERATIONS=36

# —— F13 飞书 / OA 推送（配置后 push_feishu_notification 会真实 POST）——
# FEISHU_WEBHOOK_URL=https://open.feishu.cn/open-apis/bot/v2/hook/xxxx
# OA_WEBHOOK_URL=https://你的OA回调地址/inbound/risk

# —— F01 过渡：启动时合并 external_data/*.json 到内存库（采购/合同/付款/验收/发票）——
# 亦可选启动时拉取整包 JSON（对象键为 procurement.json 等文件名）：
# EXTERNAL_DATA_BOOTSTRAP_URL=https://内网仅可信源/baozun-risk/bootstrap.json

# —— F14 定时月报：每月 1 号自动生成 HTML 到 reports/，并可顺带发飞书（需 FEISHU_WEBHOOK_URL）——
# ENABLE_SCHEDULED_MONTHLY_REPORT=1

# —— 采购数据源（integrations/datasources，详见 README.txt）——
# PROCUREMENT_DATA_SOURCE=mock
# PROCUREMENT_DATA_SOURCE=http_rest
# PROCUREMENT_REST_BASE_URL=http://127.0.0.1:8765
# PROCUREMENT_REST_LIST_PATH=/api/v1/purchase-orders
# PROCUREMENT_REST_HEADERS_JSON={"Authorization":"Bearer xxx"}
# PROCUREMENT_MERGE_MODE=merge
# PROCUREMENT_DATA_SOURCE=selectdb_mysql
# SELECTDB_MYSQL_DSN=mysql+pymysql://user:pass@host:9030/analytics
# SELECTDB_PROCUREMENT_SQL=SELECT po_number,title,category,department,applicant,supplier,supplier_id,amount,apply_date,status,has_purchase_request,pr_number,budget_code,budget_total,budget_used FROM vw_risk_procurement_po
# DATASOURCE_RELOAD_TOKEN=
